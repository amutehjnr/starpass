<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="StarPass – The premium celebrity meet & greet platform. Discover celebrities, purchase tickets, and attend exclusive events.">
  <meta name="theme-color" content="#7c3aed">
  <title><%= title || 'StarPass' %></title>

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Main CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- Page-specific CSS -->
  <%- typeof extraCss !== 'undefined' ? extraCss : '' %>

  <!-- CSRF -->
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>

<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__bg"></div>
    <!-- Floating particles -->
    <div class="hero__particles" id="particles"></div>

    <div class="hero__inner">
      <div class="hero__eyebrow">
        ✨ Premium Celebrity Experiences
      </div>
      <h1 class="hero__title">
        Meet Your<br>
        <span class="accent">Favorite Stars</span>
      </h1>
      <p class="hero__subtitle">
        Discover exclusive meet & greet events, purchase tickets, join fan clubs, and create memories with your favorite celebrities.
      </p>
      <div class="hero__cta">
        <a href="/events" class="btn btn-primary btn-xl animate-glow">
          🎪 Browse Events
        </a>
        <a href="/celebrities" class="btn btn-outline btn-xl">
          ⭐ Discover Celebrities
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Celebrities -->
  <% if (featuredCelebrities.length > 0) { %>
  <section class="section">
    <div class="container">
      <div class="section-header flex-between mb-8">
        <div>
          <div class="section-label">🌟 Featured</div>
          <h2 class="section-title">Top Celebrities</h2>
        </div>
        <a href="/celebrities" class="btn btn-secondary">View All →</a>
      </div>
      <div class="celeb-scroll">
        <div class="celeb-scroll__track">
          <% featuredCelebrities.forEach((celeb, i) => { %>
          <div class="celeb-scroll__item animate-fade-up delay-<%= Math.min(i+1,5) %>">
            <a href="/celebrities/<%= celeb.slug %>" class="celebrity-card hover-lift" style="display:block;">
              <div class="celebrity-card__img-wrap">
                <img
                  src="<%= celeb.profileImage?.url || '/images/defaults/avatar.png' %>"
                  alt="<%= celeb.stageName %>"
                  class="celebrity-card__img"
                  loading="lazy"
                  onerror="this.src='/images/defaults/avatar.png'"
                >
                <div class="celebrity-card__overlay"></div>
              </div>
              <div class="celebrity-card__body">
                <div class="celebrity-card__name">
                  <%= celeb.stageName %>
                  <% if (celeb.isVerified) { %><span title="Verified">✅</span><% } %>
                </div>
                <div class="celebrity-card__category"><%= celeb.category %></div>
                <% if (celeb.averageRating > 0) { %>
                <div class="celebrity-card__rating">
                  ⭐ <%= celeb.averageRating.toFixed(1) %>
                  <span style="color:var(--text-muted)">(<%= celeb.totalReviews %>)</span>
                </div>
                <% } %>
              </div>
            </a>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Featured Events -->
  <% if (featuredEvents.length > 0) { %>
  <section class="section" style="background:var(--bg-surface); border-top:1px solid var(--border-subtle); border-bottom:1px solid var(--border-subtle);">
    <div class="container">
      <div class="section-header">
        <div class="section-label">🔥 Don't Miss</div>
        <h2 class="section-title">Featured Events</h2>
        <p class="section-subtitle">Exclusive meet & greet opportunities with your favorite stars. Limited spots available.</p>
      </div>
      <div class="grid-3">
        <% featuredEvents.forEach((event, i) => { %>
        <a href="/events/<%= event.slug %>" class="event-card animate-fade-up delay-<%= i+1 %>" style="display:block; text-decoration:none;">
          <div class="event-card__banner">
            <img
              src="<%= event.banner?.url || '/images/defaults/event-banner.jpg' %>"
              alt="<%= event.title %>"
              class="event-card__banner-img"
              loading="lazy"
            >
            <div class="event-card__banner-overlay"></div>
            <span class="event-card__type-badge <%= event.type %>"><%= event.type %></span>
            <span class="event-card__featured-badge">⭐ Featured</span>
          </div>
          <div class="event-card__body">
            <% if (event.celebrity) { %>
            <div class="event-card__celebrity">
              <img src="<%= event.celebrity.profileImage?.url || '/images/defaults/avatar.png' %>" alt="" class="event-card__celeb-img">
              <span class="event-card__celeb-name"><%= event.celebrity.stageName %></span>
              <% if (event.celebrity.isVerified) { %><span class="event-card__celeb-verified">✅</span><% } %>
            </div>
            <% } %>
            <div class="event-card__title"><%= event.title %></div>
            <div class="event-card__meta">
              <div class="event-card__meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <%= new Date(event.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
              </div>
              <div class="event-card__meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <%= event.venue?.name || (event.type === 'virtual' ? 'Virtual Event' : 'TBA') %>
              </div>
            </div>
          </div>
          <div class="event-card__footer">
            <div>
              <div class="event-card__price-label">From</div>
              <div class="event-card__price">
                $<%= Math.min(...event.ticketCategories.filter(c=>c.isActive).map(c=>c.price)) || '0' %>
              </div>
            </div>
            <span class="btn btn-primary btn-sm">Get Tickets</span>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Upcoming Events -->
  <% if (upcomingEvents.length > 0) { %>
  <section class="section">
    <div class="container">
      <div class="section-header flex-between mb-8">
        <div>
          <div class="section-label">📅 Coming Soon</div>
          <h2 class="section-title">Upcoming Events</h2>
        </div>
        <a href="/events" class="btn btn-secondary">All Events →</a>
      </div>
      <div class="grid-4">
        <% upcomingEvents.forEach((event, i) => { %>
        <a href="/events/<%= event.slug %>" class="event-card animate-fade-up" style="display:block;text-decoration:none;animation-delay:<%=i*0.07%>s">
          <div class="event-card__banner">
            <img src="<%= event.banner?.url || '/images/defaults/event-banner.jpg' %>" alt="<%= event.title %>" class="event-card__banner-img" loading="lazy">
            <div class="event-card__banner-overlay"></div>
            <span class="event-card__type-badge <%= event.type %>"><%= event.type %></span>
          </div>
          <div class="event-card__body">
            <% if (event.celebrity) { %>
            <div class="event-card__celebrity">
              <img src="<%= event.celebrity.profileImage?.url || '/images/defaults/avatar.png' %>" alt="" class="event-card__celeb-img">
              <span class="event-card__celeb-name"><%= event.celebrity.stageName %></span>
            </div>
            <% } %>
            <div class="event-card__title"><%= event.title %></div>
            <div class="event-card__meta">
              <div class="event-card__meta-item">
                📅 <%= new Date(event.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %>
              </div>
            </div>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- How It Works -->
  <section class="section" style="background:var(--bg-surface);border-top:1px solid var(--border-subtle);">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Simple Process</div>
        <h2 class="section-title">How StarPass Works</h2>
        <p class="section-subtitle">From discovery to unforgettable memories — all in four simple steps.</p>
      </div>
      <div class="grid-4">
        <% [
          {icon:'🔍',step:'01',title:'Discover',desc:'Browse verified celebrities and find upcoming events that match your interests.'},
          {icon:'🎟️',step:'02',title:'Get Tickets',desc:'Choose your ticket tier — General, Premium, VIP, or Platinum VIP.'},
          {icon:'💳',step:'03',title:'Pay Securely',desc:'Upload your gift card for secure, instant payment verification by our team.'},
          {icon:'⭐',step:'04',title:'Experience',desc:'Attend the event, meet your celebrity, and create memories that last forever.'}
        ].forEach((item, i) => { %>
        <div class="card animate-fade-up delay-<%= i+1 %>" style="text-align:center;">
          <div class="card__body">
            <div style="font-size:48px;margin-bottom:var(--space-3)"><%= item.icon %></div>
            <div style="font-size:var(--text-xs);font-weight:700;color:var(--color-brand-fuchsia);letter-spacing:0.1em;margin-bottom:var(--space-2)">STEP <%= item.step %></div>
            <h4 style="margin-bottom:var(--space-3)"><%= item.title %></h4>
            <p style="font-size:var(--text-sm);"><%= item.desc %></p>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section">
    <div class="container">
      <div style="background:var(--gradient-brand);border-radius:var(--radius-2xl);padding:var(--space-16) var(--space-12);text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 50% -20%,rgba(255,255,255,0.1),transparent);pointer-events:none;"></div>
        <h2 style="font-size:clamp(var(--text-2xl),4vw,var(--text-4xl));font-weight:800;color:#fff;margin-bottom:var(--space-4)">Ready for Your Star Moment?</h2>
        <p style="color:rgba(255,255,255,0.8);font-size:var(--text-lg);margin-bottom:var(--space-8);max-width:500px;margin-left:auto;margin-right:auto;">Join thousands of fans who've already experienced unforgettable celebrity encounters.</p>
        <div style="display:flex;gap:var(--space-4);justify-content:center;flex-wrap:wrap;">
          <a href="/auth/register" class="btn btn-xl" style="background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.3);backdrop-filter:blur(8px);">Create Free Account</a>
          <a href="/events" class="btn btn-xl" style="background:#fff;color:var(--color-brand-violet);">Browse Events</a>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include('../partials/footer') %>

<script>
// Particle animation
(function(){
  const container = document.getElementById('particles');
  if (!container) return;
  for (let i = 0; i < 30; i++) {
    const p = document.createElement('div');
    p.className = 'hero__particle';
    p.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;--duration:${3+Math.random()*4}s;--delay:-${Math.random()*5}s;--opacity:${0.2+Math.random()*0.4};`;
  }
})();
</script>

</body>
</html>
