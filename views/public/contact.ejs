<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main>
  <section class="section">
    <div class="container" style="max-width:600px;">
      <div class="section-header">
        <div class="section-label">💬 Get In Touch</div>
        <h1 class="section-title">Contact Us</h1>
        <p class="section-subtitle">Questions about an event, payment, or your account? We're here to help.</p>
      </div>

      <div class="content-block mb-6" style="text-align:center;">
        <div style="font-size:40px;margin-bottom:var(--space-4);">✉️</div>
        <p style="color:var(--text-secondary);margin-bottom:var(--space-5);">Reach our support team directly and we'll get back to you within 24 hours.</p>
        <a href="mailto:support@starpass.com" class="btn btn-primary btn-lg">support@starpass.com</a>
      </div>

      <div class="grid-2 gap-4">
        <a href="/faq" class="card hover-lift" style="display:block;padding:var(--space-6);text-align:center;text-decoration:none;">
          <div style="font-size:32px;margin-bottom:var(--space-3);">❓</div>
          <div style="font-weight:600;">Visit our FAQ</div>
        </a>
        <a href="/fan/payments" class="card hover-lift" style="display:block;padding:var(--space-6);text-align:center;text-decoration:none;">
          <div style="font-size:32px;margin-bottom:var(--space-3);">💳</div>
          <div style="font-weight:600;">Payment Status</div>
        </a>
      </div>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
</body>
</html>