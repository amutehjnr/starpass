<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-label">🎪 Discover</div>
        <h1 class="section-title">Browse Events</h1>
        <p class="section-subtitle"><%= pagination.total %> events available</p>
      </div>

      <form method="GET" action="/events" class="content-block mb-8">
        <div class="form-row" style="grid-template-columns:2fr 1fr 1fr 1fr auto;align-items:end;">
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Search</label>
            <input type="text" name="search" class="form-input" value="<%= filters.search || '' %>" placeholder="Search events…">
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Type</label>
            <select name="type" class="form-select">
              <option value="">All Types</option>
              <option value="physical" <%= filters.type === 'physical' ? 'selected' : '' %>>Physical</option>
              <option value="virtual" <%= filters.type === 'virtual' ? 'selected' : '' %>>Virtual</option>
              <option value="hybrid" <%= filters.type === 'hybrid' ? 'selected' : '' %>>Hybrid</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Category</label>
            <select name="category" class="form-select">
              <option value="">All Categories</option>
              <% ['meet_greet','fan_conference','autograph_session','photo_session','vip_experience','birthday_shoutout','concert','other'].forEach(c => { %>
              <option value="<%= c %>" <%= filters.category === c ? 'selected' : '' %>><%= c.replace(/_/g,' ').replace(/\b\w/g, l => l.toUpperCase()) %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Sort</label>
            <select name="sort" class="form-select">
              <option value="soonest" <%= filters.sort === 'soonest' ? 'selected' : '' %>>Soonest</option>
              <option value="featured" <%= filters.sort === 'featured' ? 'selected' : '' %>>Featured</option>
              <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary">Search</button>
        </div>
      </form>

      <% if (events.length === 0) { %>
      <div style="text-align:center;padding:var(--space-20);">
        <div style="font-size:64px;margin-bottom:var(--space-4);">🔍</div>
        <h4 style="margin-bottom:var(--space-3);">No events found</h4>
        <p style="color:var(--text-muted);">Try adjusting your search or filters.</p>
      </div>
      <% } else { %>
      <div class="grid-4">
        <% events.forEach(event => { %>
        <a href="/events/<%= event.slug %>" class="event-card" style="display:block;text-decoration:none;">
          <div class="event-card__banner">
            <img src="<%= event.banner?.url || '/images/defaults/event-banner.jpg' %>" class="event-card__banner-img" loading="lazy">
            <div class="event-card__banner-overlay"></div>
            <span class="event-card__type-badge <%= event.type %>"><%= event.type %></span>
            <% if (event.isFeatured) { %><span class="event-card__featured-badge">⭐</span><% } %>
          </div>
          <div class="event-card__body">
            <% if (event.celebrity) { %>
            <div class="event-card__celebrity">
              <img src="<%= event.celebrity.profileImage?.url || '/images/defaults/avatar.png' %>" alt="" class="event-card__celeb-img">
              <span class="event-card__celeb-name"><%= event.celebrity.stageName %></span>
              <% if (event.celebrity.isVerified) { %><span class="event-card__celeb-verified">✅</span><% } %>
            </div>
            <% } %>
            <div class="event-card__title"><%= event.title %></div>
            <div class="event-card__meta">
              <div class="event-card__meta-item">📅 <%= new Date(event.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></div>
            </div>
          </div>
          <div class="event-card__footer">
            <div>
              <div class="event-card__price-label">From</div>
              <div class="event-card__price">$<%= Math.min(...event.ticketCategories.filter(c=>c.isActive).map(c=>c.price)) || 0 %></div>
            </div>
            <div class="event-card__capacity">
              <div class="event-card__cap-bar"><div class="event-card__cap-fill" style="width:<%= event.totalCapacity > 0 ? Math.min(100,(event.totalSold/event.totalCapacity)*100) : 0 %>%;"></div></div>
            </div>
          </div>
        </a>
        <% }) %>
      </div>

      <% if (pagination.pages > 1) { %>
      <div class="pagination">
        <% for (let p = 1; p <= pagination.pages; p++) { %>
        <a href="/events?page=<%= p %><%= filters.search ? '&search=' + filters.search : '' %><%= filters.type ? '&type=' + filters.type : '' %><%= filters.category ? '&category=' + filters.category : '' %><%= filters.sort ? '&sort=' + filters.sort : '' %>" class="pagination__btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
        <% } %>
      </div>
      <% } %>
      <% } %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
</body>
</html>