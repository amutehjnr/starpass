<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main>
  <section class="section">
    <div class="container" style="max-width:680px;">
      <div class="section-header">
        <div class="section-label">⭐ Join StarPass</div>
        <h1 class="section-title">Apply as a Celebrity</h1>
        <p class="section-subtitle">Tell us about yourself. Our team typically reviews applications within 2-3 business days.</p>
      </div>

      <form action="/apply" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="content-block mb-5">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-5);">Account Information</h3>
          <p class="form-hint mb-4">This account manages the celebrity profile — it can be the celebrity themselves or their manager.</p>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">First Name <span class="required">*</span></label>
              <input type="text" name="firstName" class="form-input" required maxlength="50">
            </div>
            <div class="form-group">
              <label class="form-label">Last Name <span class="required">*</span></label>
              <input type="text" name="lastName" class="form-input" required maxlength="50">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email Address <span class="required">*</span></label>
            <input type="email" name="email" class="form-input" required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Password <span class="required">*</span></label>
              <input type="password" name="password" class="form-input" required minlength="8" placeholder="Min. 8 characters">
            </div>
            <div class="form-group">
              <label class="form-label">Confirm Password <span class="required">*</span></label>
              <input type="password" name="confirmPassword" class="form-input" required minlength="8">
            </div>
          </div>
        </div>

        <div class="content-block mb-5">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-5);">Celebrity Profile</h3>
          <div class="form-group">
            <label class="form-label">Stage Name <span class="required">*</span></label>
            <input type="text" name="stageName" class="form-input" required maxlength="100" placeholder="How you're known publicly">
          </div>
          <div class="form-group">
            <label class="form-label">Category <span class="required">*</span></label>
            <select name="category" class="form-select" required>
              <% ['actor','musician','athlete','comedian','influencer','model','gamer','chef','author','other'].forEach(cat => { %>
              <option value="<%= cat %>"><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Short Bio</label>
            <input type="text" name="shortBio" class="form-input" maxlength="300" placeholder="One-line tagline">
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Full Biography</label>
            <textarea name="biography" class="form-textarea" rows="5" maxlength="5000" placeholder="Tell fans (and our review team) about your career…"></textarea>
          </div>
        </div>

        <div class="content-block mb-6">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-2);">Verification Documents</h3>
          <p class="form-hint mb-4">Upload anything that helps us confirm your identity — ID, press coverage, verified social profiles, official websites, etc. Up to 3 files.</p>
          <div class="upload-zone">
            <input type="file" name="documents" accept="image/*" multiple class="upload-zone__input">
            <div style="font-size:32px;margin-bottom:var(--space-2);">📎</div>
            <div class="upload-zone__title">Upload Documents</div>
            <div class="upload-zone__hint">Up to 3 images</div>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-full btn-lg" id="submitBtn">Submit Application</button>
      </form>

      <p style="text-align:center;color:var(--text-muted);font-size:var(--text-sm);margin-top:var(--space-6);">
        Already have an account? <a href="/auth/login" style="color:var(--color-brand-violet);font-weight:600;">Sign in</a>
      </p>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script>
document.querySelector('form').addEventListener('submit', function () {
  const btn = document.getElementById('submitBtn');
  btn.classList.add('loading');
  btn.disabled = true;
  btn.textContent = '';
});
</script>
</body>
</html>