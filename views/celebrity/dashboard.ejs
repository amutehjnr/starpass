<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <button class="btn btn-secondary btn-sm mb-6" id="sidebarToggle" style="display:none;">☰ Menu</button>

    <div class="page-header flex-between">
      <div style="display:flex;align-items:center;gap:var(--space-4);">
        <img src="<%= celebrity.profileImage?.url || '/images/defaults/avatar.png' %>" alt="<%= celebrity.stageName %>" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid var(--border-brand);" onerror="this.src='/images/defaults/avatar.png'">
        <div>
          <h1 class="page-title" style="display:flex;align-items:center;gap:var(--space-2);">
            <%= celebrity.stageName %>
            <% if (celebrity.isVerified) { %><span title="Verified" style="font-size:var(--text-xl);">✅</span><% } %>
          </h1>
          <p class="page-subtitle" style="text-transform:capitalize;"><%= celebrity.category %></p>
        </div>
      </div>
      <a href="/celebrity/events/create" class="btn btn-primary">+ Create Event</a>
    </div>

    <% if (!celebrity.isVerified) { %>
    <div class="alert alert-warning mb-8">
      <span class="alert__icon">⏳</span>
      <div class="alert__content">
        <strong>Verification pending</strong> — Your profile is awaiting admin verification. You won't be able to publish events until you're verified.
      </div>
    </div>
    <% } %>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card animate-fade-up">
        <div class="stat-card__icon">💰</div>
        <div class="stat-card__label">Total Revenue</div>
        <div class="stat-card__value">$<%= (stats.totalRevenue || 0).toLocaleString() %></div>
      </div>
      <div class="stat-card animate-fade-up delay-1">
        <div class="stat-card__icon">🎪</div>
        <div class="stat-card__label">Events Hosted</div>
        <div class="stat-card__value"><%= stats.totalEvents || 0 %></div>
      </div>
      <div class="stat-card animate-fade-up delay-2">
        <div class="stat-card__icon">🎟️</div>
        <div class="stat-card__label">Tickets Sold</div>
        <div class="stat-card__value"><%= stats.totalSold || 0 %></div>
      </div>
      <div class="stat-card animate-fade-up delay-3">
        <div class="stat-card__icon">👥</div>
        <div class="stat-card__label">Total Fans</div>
        <div class="stat-card__value"><%= (stats.totalFans || 0).toLocaleString() %></div>
      </div>
      <div class="stat-card animate-fade-up delay-4">
        <div class="stat-card__icon">⭐</div>
        <div class="stat-card__label">Average Rating</div>
        <div class="stat-card__value"><%= stats.averageRating ? stats.averageRating.toFixed(1) : '–' %></div>
      </div>
    </div>

    <div class="grid-2 gap-6">

      <!-- Upcoming Events -->
      <div class="content-block">
        <div class="card__header">
          <h3 style="font-size:var(--text-lg);">🎪 Upcoming Events</h3>
          <a href="/celebrity/events" class="btn btn-ghost btn-sm">View All →</a>
        </div>

        <% if (upcomingEvents.length === 0) { %>
        <div style="text-align:center;padding:var(--space-10);color:var(--text-muted);">
          <div style="font-size:48px;margin-bottom:var(--space-3);">🎪</div>
          <p>No upcoming events.</p>
          <a href="/celebrity/events/create" class="btn btn-primary btn-sm mt-4">Create Your First Event</a>
        </div>
        <% } else { %>
        <div>
          <% upcomingEvents.forEach(event => { %>
          <a href="/celebrity/events/<%= event._id %>/edit" style="display:flex;align-items:center;gap:var(--space-4);padding:var(--space-4) var(--space-5);border-bottom:1px solid var(--border-subtle);text-decoration:none;color:inherit;">
            <img src="<%= event.banner?.url || '/images/defaults/event-banner.jpg' %>" style="width:56px;height:56px;border-radius:var(--radius-md);object-fit:cover;background:var(--bg-elevated);flex-shrink:0;">
            <div style="flex:1;min-width:0;">
              <div style="font-weight:600;font-size:var(--text-sm);" class="truncate"><%= event.title %></div>
              <div style="font-size:var(--text-xs);color:var(--text-muted);"><%= new Date(event.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></div>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div style="font-size:var(--text-sm);font-weight:700;"><%= event.totalSold %>/<%= event.totalCapacity %></div>
              <div style="font-size:10px;color:var(--text-muted);">sold</div>
            </div>
          </a>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Recent Ticket Sales -->
      <div class="content-block">
        <div class="card__header">
          <h3 style="font-size:var(--text-lg);">🎟️ Recent Ticket Sales</h3>
        </div>

        <% if (recentTickets.length === 0) { %>
        <div style="text-align:center;padding:var(--space-10);color:var(--text-muted);">
          <div style="font-size:48px;margin-bottom:var(--space-3);">🎟️</div>
          <p>No ticket sales yet.</p>
        </div>
        <% } else { %>
        <div class="table-wrap">
          <table class="table">
            <thead><tr><th>Fan</th><th>Event</th><th>Category</th></tr></thead>
            <tbody>
              <% recentTickets.forEach(ticket => { %>
              <tr>
                <td>
                  <div style="display:flex;align-items:center;gap:var(--space-2);">
                    <img src="<%= ticket.fan?.avatar?.url || '/images/defaults/avatar.png' %>" style="width:26px;height:26px;border-radius:50%;object-fit:cover;" onerror="this.src='/images/defaults/avatar.png'">
                    <span style="font-size:var(--text-sm);"><%= ticket.fan?.firstName %> <%= ticket.fan?.lastName %></span>
                  </div>
                </td>
                <td style="font-size:var(--text-sm);" class="truncate"><%= ticket.event?.title %></td>
                <td><span class="badge badge-brand" style="text-transform:capitalize;"><%= ticket.ticketCategory.replace('_',' ') %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>

    <!-- Quick Actions -->
    <div class="content-block mt-6">
      <h3 style="font-size:var(--text-lg);margin-bottom:var(--space-5);">Quick Actions</h3>
      <div class="grid-4">
        <a href="/celebrity/events/create" class="card hover-lift" style="display:block;padding:var(--space-5);text-align:center;text-decoration:none;">
          <div style="font-size:32px;margin-bottom:var(--space-3);">🎪</div>
          <div style="font-weight:600;font-size:var(--text-sm);">Create Event</div>
        </a>
        <a href="/celebrity/fan-club" class="card hover-lift" style="display:block;padding:var(--space-5);text-align:center;text-decoration:none;">
          <div style="font-size:32px;margin-bottom:var(--space-3);">⭐</div>
          <div style="font-weight:600;font-size:var(--text-sm);">Fan Club</div>
        </a>
        <a href="/celebrity/analytics" class="card hover-lift" style="display:block;padding:var(--space-5);text-align:center;text-decoration:none;">
          <div style="font-size:32px;margin-bottom:var(--space-3);">📈</div>
          <div style="font-weight:600;font-size:var(--text-sm);">Analytics</div>
        </a>
        <a href="/celebrity/profile" class="card hover-lift" style="display:block;padding:var(--space-5);text-align:center;text-decoration:none;">
          <div style="font-size:32px;margin-bottom:var(--space-3);">👤</div>
          <div style="font-weight:600;font-size:var(--text-sm);">Edit Profile</div>
        </a>
      </div>
    </div>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>