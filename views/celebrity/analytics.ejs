<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../../partials/sidebar') %>

  <main class="dashboard-content">
    <button class="btn btn-secondary btn-sm mb-6" id="sidebarToggle" style="display:none;">☰ Menu</button>

    <div class="page-header">
      <h1 class="page-title">Analytics</h1>
      <p class="page-subtitle">Performance across your events</p>
    </div>

    <!-- Tickets by Category -->
    <div class="content-block mb-6">
      <h3 style="font-size:var(--text-lg);margin-bottom:var(--space-5);">🎟️ Tickets by Category</h3>
      <% if (ticketsByCategory.length === 0) { %>
      <div style="text-align:center;padding:var(--space-8);color:var(--text-muted);">No ticket sales yet.</div>
      <% } else {
        const maxRev = Math.max(...ticketsByCategory.map(c => c.revenue), 1);
      %>
      <% ticketsByCategory.forEach(cat => { %>
      <div style="margin-bottom:var(--space-5);">
        <div class="flex-between mb-2">
          <span style="font-weight:600;font-size:var(--text-sm);text-transform:capitalize;"><%= cat._id.replace('_',' ') %></span>
          <span style="font-size:var(--text-sm);color:var(--text-muted);"><%= cat.count %> sold · $<%= cat.revenue.toLocaleString() %></span>
        </div>
        <div class="event-card__cap-bar" style="width:100%;">
          <div class="event-card__cap-fill" style="width:<%= (cat.revenue/maxRev)*100 %>%;"></div>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>

    <!-- Monthly Revenue -->
    <div class="content-block mb-6">
      <h3 style="font-size:var(--text-lg);margin-bottom:var(--space-5);">📈 Revenue – Last 6 Months</h3>
      <% if (monthlyRevenue.length === 0) { %>
      <div style="text-align:center;padding:var(--space-8);color:var(--text-muted);">No revenue data yet.</div>
      <% } else {
        const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        const maxMonthRev = Math.max(...monthlyRevenue.map(m => m.revenue), 1);
      %>
      <div style="display:flex;align-items:flex-end;gap:var(--space-4);height:180px;padding-top:var(--space-4);">
        <% monthlyRevenue.forEach(m => { %>
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;">
          <div style="font-size:var(--text-xs);font-weight:700;margin-bottom:var(--space-2);">$<%= m.revenue.toLocaleString() %></div>
          <div style="width:100%;background:var(--gradient-brand);border-radius:var(--radius-sm) var(--radius-sm) 0 0;height:<%= Math.max(4, (m.revenue/maxMonthRev)*120) %>px;"></div>
          <div style="font-size:var(--text-xs);color:var(--text-muted);margin-top:var(--space-2);"><%= monthNames[m._id.month - 1] %></div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Event Performance -->
    <div class="content-block">
      <h3 style="font-size:var(--text-lg);margin-bottom:var(--space-5);">🎪 Event Performance</h3>
      <% if (eventStats.length === 0) { %>
      <div style="text-align:center;padding:var(--space-8);color:var(--text-muted);">No events yet.</div>
      <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead><tr><th>Event</th><th>Date</th><th>Status</th><th>Sold</th><th>Revenue</th></tr></thead>
          <tbody>
            <% eventStats.forEach(e => { %>
            <tr>
              <td style="font-weight:600;color:var(--text-primary);"><%= e.title %></td>
              <td><%= new Date(e.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></td>
              <td><span class="badge badge-<%= e.status === 'published' ? 'success' : e.status === 'draft' ? 'muted' : e.status === 'cancelled' ? 'error' : 'info' %>" style="text-transform:capitalize;"><%= e.status %></span></td>
              <td><%= e.totalSold %>/<%= e.totalCapacity %></td>
              <td style="font-weight:700;color:var(--color-success);">$<%= (e.revenue || 0).toLocaleString() %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </main>
</div>

<%- include('../../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>