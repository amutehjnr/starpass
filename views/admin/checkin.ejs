<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header flex-between">
      <div>
        <h1 class="page-title">Event Check-In</h1>
        <p class="page-subtitle"><%= event.title %> — <%= event.celebrity?.stageName %></p>
      </div>
      <div style="text-align:right;">
        <div style="font-size:var(--text-2xl);font-weight:800;"><%= checkedInCount %>/<%= event.totalSold %></div>
        <div style="font-size:var(--text-xs);color:var(--text-muted);">checked in</div>
      </div>
    </div>

    <div class="grid-2 gap-6">
      <div>
        <div class="content-block mb-5">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-4);">🔢 Manual Entry</h3>
          <form id="checkinForm">
            <div class="form-group">
              <label class="form-label">Verification Code</label>
              <input type="text" id="verificationCode" class="form-input text-mono" placeholder="e.g. AB12CD34EF56GH78" autocomplete="off" autofocus>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Check In</button>
          </form>
        </div>

        <div class="content-block">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-4);">📷 Scan QR Code</h3>
          <button type="button" id="scannerToggle" class="btn btn-secondary btn-full mb-4">Start Camera Scanner</button>
          <div id="qrReader" style="width:100%;display:none;border-radius:var(--radius-md);overflow:hidden;"></div>
        </div>
      </div>

      <div>
        <div class="content-block">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-4);">Recent Check-Ins</h3>
          <div id="checkinList" style="display:flex;flex-direction:column;gap:var(--space-3);max-height:500px;overflow-y:auto;">
            <p style="color:var(--text-muted);font-size:var(--text-sm);">Check-ins will appear here in real time.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
<script>
(function () {
  const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
  const eventId = '<%= event._id %>';
  const form = document.getElementById('checkinForm');
  const input = document.getElementById('verificationCode');

  async function submitCheckin(code) {
    if (!code) return;
    try {
      const res = await fetch('/admin/checkin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
        body: JSON.stringify({ verificationCode: code, eventId }),
      });
      const data = await res.json();
      if (window.showToast) {
        window.showToast(data.success ? 'Checked In ✅' : 'Check-In Failed', data.message, data.success ? 'success' : 'error');
      }
      if (data.success) input.value = '';
    } catch {
      if (window.showToast) window.showToast('Error', 'Something went wrong.', 'error');
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    submitCheckin(input.value.trim());
  });

  // Camera scanner (library loaded on demand)
  const toggleBtn = document.getElementById('scannerToggle');
  const readerDiv = document.getElementById('qrReader');
  let scanner = null;
  let scanning = false;

  toggleBtn.addEventListener('click', async () => {
    if (scanning) {
      if (scanner) await scanner.stop().catch(() => {});
      readerDiv.style.display = 'none';
      toggleBtn.textContent = 'Start Camera Scanner';
      scanning = false;
      return;
    }

    if (!window.Html5Qrcode) {
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js';
      document.head.appendChild(script);
      await new Promise((resolve) => { script.onload = resolve; });
    }

    readerDiv.style.display = 'block';
    toggleBtn.textContent = 'Stop Camera Scanner';
    scanning = true;

    scanner = new window.Html5Qrcode('qrReader');
    scanner.start(
      { facingMode: 'environment' },
      { fps: 10, qrbox: 250 },
      (decodedText) => {
        let code = decodedText;
        try {
          const parsed = JSON.parse(decodedText);
          code = parsed.v || parsed.verificationCode || decodedText;
        } catch { /* plain text code */ }
        submitCheckin(code);
      },
      () => { /* ignore per-frame scan errors */ }
    ).catch(() => {
      if (window.showToast) window.showToast('Camera Error', 'Could not access camera.', 'error');
      scanning = false;
      readerDiv.style.display = 'none';
      toggleBtn.textContent = 'Start Camera Scanner';
    });
  });
})();
</script>
</body>
</html>