<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header">
      <h1 class="page-title">Gift Card Reviews</h1>
      <p class="page-subtitle"><%= pagination.total %> submissions</p>
    </div>

    <div class="flex gap-2 mb-6" style="flex-wrap:wrap;">
      <% ['pending','under_review','approved','rejected','expired'].forEach(s => { %>
      <a href="/admin/gift-cards?status=<%= s %>" class="btn btn-sm <%= currentStatus === s ? 'btn-primary' : 'btn-secondary' %>" style="text-transform:capitalize;"><%= s.replace('_',' ') %></a>
      <% }) %>
    </div>

    <% if (payments.length === 0) { %>
    <div class="content-block" style="text-align:center;padding:var(--space-16);">
      <div style="font-size:48px;margin-bottom:var(--space-3);">✅</div>
      <p style="color:var(--text-muted);">No submissions in this status.</p>
    </div>
    <% } else { %>
    <div class="table-wrap content-block" style="padding:0;">
      <table class="table">
        <thead><tr><th>Fan</th><th>Event</th><th>Card</th><th>Value</th><th>Submitted</th><th></th></tr></thead>
        <tbody>
          <% payments.forEach(p => { %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:var(--space-2);">
                <img src="<%= p.fan?.avatar?.url || '/images/defaults/avatar.png' %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover;">
                <span style="font-size:var(--text-sm);"><%= p.fan?.firstName %> <%= p.fan?.lastName %></span>
              </div>
            </td>
            <td style="font-size:var(--text-sm);"><%= p.event?.title %></td>
            <td><span class="badge badge-muted" style="text-transform:capitalize;"><%= p.cardType.replace('_',' ') %></span></td>
            <td style="font-weight:700;color:var(--color-success);">$<%= p.declaredValue %></td>
            <td style="font-size:var(--text-xs);color:var(--text-muted);"><%= new Date(p.createdAt).toLocaleDateString() %></td>
            <td><a href="/admin/gift-cards/<%= p._id %>" class="btn btn-primary btn-sm">Review</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (pagination.pages > 1) { %>
    <div class="pagination">
      <% for (let p = 1; p <= pagination.pages; p++) { %>
      <a href="/admin/gift-cards?page=<%= p %>&status=<%= currentStatus %>" class="pagination__btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
      <% } %>
    </div>
    <% } %>
    <% } %>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>