<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header">
      <h1 class="page-title">Audit Logs</h1>
      <p class="page-subtitle"><%= pagination.total %> total entries</p>
    </div>

    <form method="GET" action="/admin/audit-logs" class="content-block mb-6">
      <div class="form-row" style="grid-template-columns:1fr auto;align-items:end;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label">Filter by Action</label>
          <input type="text" name="action" class="form-input" value="<%= filters.action || '' %>" placeholder="e.g. payment:approve">
        </div>
        <button type="submit" class="btn btn-primary">Filter</button>
      </div>
    </form>

    <div class="table-wrap content-block" style="padding:0;">
      <table class="table">
        <thead><tr><th>Action</th><th>Actor</th><th>Resource</th><th>Status</th><th>IP</th><th>Time</th></tr></thead>
        <tbody>
          <% logs.forEach(log => { %>
          <tr>
            <td style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--color-brand-violet);font-weight:600;"><%= log.action %></td>
            <td style="font-size:var(--text-sm);"><%= log.actor ? `${log.actor.firstName} ${log.actor.lastName}` : 'Anonymous' %> <span style="color:var(--text-muted);font-size:var(--text-xs);">(<%= log.actorRole %>)</span></td>
            <td style="font-size:var(--text-sm);color:var(--text-muted);"><%= log.resource || '–' %></td>
            <td><span class="badge badge-<%= log.status === 'success' ? 'success' : 'error' %>"><%= log.status %></span></td>
            <td style="font-size:var(--text-xs);color:var(--text-muted);font-family:var(--font-mono);"><%= log.ipAddress %></td>
            <td style="font-size:var(--text-xs);color:var(--text-muted);"><%= new Date(log.createdAt).toLocaleString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (pagination.pages > 1) { %>
    <div class="pagination">
      <% for (let p = 1; p <= pagination.pages; p++) { %>
      <a href="/admin/audit-logs?page=<%= p %><%= filters.action ? '&action=' + filters.action : '' %>" class="pagination__btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
      <% } %>
    </div>
    <% } %>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>