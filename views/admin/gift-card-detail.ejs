<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header flex-between">
      <div>
        <a href="/admin/gift-cards" class="btn btn-ghost btn-sm mb-3">← Back to Reviews</a>
        <h1 class="page-title">Review Gift Card Payment</h1>
        <p class="page-subtitle">Submitted <%= new Date(payment.createdAt).toLocaleString() %></p>
      </div>
      <span class="badge badge-<%= payment.status === 'pending' ? 'warning' : payment.status === 'under_review' ? 'info' : payment.status === 'approved' ? 'success' : 'error' %>" style="font-size:var(--text-sm);padding:6px 16px;">
        <%= payment.status.replace('_',' ').toUpperCase() %>
      </span>
    </div>

    <div class="grid-2 gap-6">

      <!-- Left: Gift Card Details -->
      <div>
        <!-- Fan Info -->
        <div class="content-block mb-5">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-5);">👤 Fan Information</h3>
          <div style="display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-5);">
            <img src="<%= payment.fan?.avatar?.url || '/images/defaults/avatar.png' %>" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid var(--border-brand);" onerror="this.src='/images/defaults/avatar.png'">
            <div>
              <div style="font-weight:700;font-size:var(--text-lg);"><%= payment.fan?.firstName %> <%= payment.fan?.lastName %></div>
              <div style="font-size:var(--text-sm);color:var(--text-muted);"><%= payment.fan?.email %></div>
              <div style="font-size:var(--text-xs);color:var(--text-muted);"><%= payment.fan?.country || 'Country not set' %></div>
            </div>
          </div>
        </div>

        <!-- Payment Details -->
        <div class="content-block mb-5">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-5);">💳 Gift Card Details</h3>
          <% const rows = [
            ['Card Type', payment.cardType.replace('_',' ').toUpperCase()],
            ['Declared Value', `$${payment.declaredValue} ${payment.currency}`],
            ['Card Number', payment.cardNumber || 'Not provided'],
            ['Submitted', new Date(payment.submittedAt).toLocaleString()],
            ['Expires', new Date(payment.expiresAt).toLocaleString()],
          ]; %>
          <% rows.forEach(([label, value]) => { %>
          <div style="display:flex;justify-content:space-between;padding:var(--space-3) 0;border-bottom:1px solid var(--border-subtle);">
            <span style="font-size:var(--text-sm);color:var(--text-muted);"><%= label %></span>
            <span style="font-size:var(--text-sm);font-weight:600;"><%= value %></span>
          </div>
          <% }) %>

          <% if (payment.isFlagged) { %>
          <div class="alert alert-error mt-4">
            <span class="alert__icon">🚩</span>
            <div class="alert__content">
              <strong>Fraud Flags Detected:</strong>
              <% payment.fraudFlags.forEach(flag => { %>
              <div>• <%= flag.flag %> (<%= flag.severity %> severity)</div>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>

        <!-- Event/Ticket Details -->
        <div class="content-block">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-5);">🎪 Event & Ticket</h3>
          <% const trows = [
            ['Event', payment.event?.title || 'Unknown'],
            ['Event Date', payment.event?.startDate ? new Date(payment.event.startDate).toLocaleDateString() : '–'],
            ['Ticket #', payment.ticket?.ticketNumber || '–'],
            ['Category', payment.ticket?.ticketLabel || payment.ticket?.ticketCategory || '–'],
            ['Ticket Price', payment.ticket?.price ? `$${payment.ticket.price}` : '–'],
          ]; %>
          <% trows.forEach(([label, value]) => { %>
          <div style="display:flex;justify-content:space-between;padding:var(--space-3) 0;border-bottom:1px solid var(--border-subtle);">
            <span style="font-size:var(--text-sm);color:var(--text-muted);"><%= label %></span>
            <span style="font-size:var(--text-sm);font-weight:600;"><%= value %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Right: Images + Actions -->
      <div>
        <!-- Gift Card Images -->
        <div class="content-block mb-5">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-5);">🖼️ Uploaded Images</h3>
          <div class="review-card__images">
            <% if (payment.images?.front?.url) { %>
            <div>
              <div style="font-size:var(--text-xs);color:var(--text-muted);margin-bottom:var(--space-2);font-weight:600;text-transform:uppercase;">Front</div>
              <div class="review-card__img-wrap" onclick="openImage('<%= payment.images.front.url %>')">
                <img src="<%= payment.images.front.url %>" alt="Gift Card Front" class="review-card__img">
              </div>
            </div>
            <% } %>
            <% if (payment.images?.back?.url) { %>
            <div>
              <div style="font-size:var(--text-xs);color:var(--text-muted);margin-bottom:var(--space-2);font-weight:600;text-transform:uppercase;">Back</div>
              <div class="review-card__img-wrap" onclick="openImage('<%= payment.images.back.url %>')">
                <img src="<%= payment.images.back.url %>" alt="Gift Card Back" class="review-card__img">
              </div>
            </div>
            <% } %>
            <% if (payment.images?.receipt?.url) { %>
            <div>
              <div style="font-size:var(--text-xs);color:var(--text-muted);margin-bottom:var(--space-2);font-weight:600;text-transform:uppercase;">Receipt</div>
              <div class="review-card__img-wrap" onclick="openImage('<%= payment.images.receipt.url %>')">
                <img src="<%= payment.images.receipt.url %>" alt="Receipt" class="review-card__img">
              </div>
            </div>
            <% } %>
          </div>
          <% if (!payment.images?.front?.url) { %>
          <div style="text-align:center;padding:var(--space-8);color:var(--text-muted);">No images uploaded</div>
          <% } %>
        </div>

        <% if (['pending','under_review'].includes(payment.status)) { %>
        <!-- Approve -->
        <div class="content-block mb-4" style="border-color:rgba(34,197,94,0.25);">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-4);color:var(--color-success);">✅ Approve Payment</h3>
          <form action="/admin/gift-cards/<%= payment._id %>/approve" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label class="form-label">Approval Notes (optional)</label>
              <textarea name="approvalNotes" class="form-textarea" rows="2" placeholder="Optional note about this approval…"></textarea>
            </div>
            <button type="submit" class="btn btn-success btn-full" onclick="return confirm('Approve this payment and activate the ticket?')">
              ✅ Approve & Activate Ticket
            </button>
          </form>
        </div>

        <!-- Reject -->
        <div class="content-block mb-4" style="border-color:rgba(239,68,68,0.25);">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-4);color:var(--color-error);">❌ Reject Payment</h3>
          <form action="/admin/gift-cards/<%= payment._id %>/reject" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label class="form-label">Rejection Reason <span class="required">*</span></label>
              <textarea name="rejectionReason" class="form-textarea" rows="3" placeholder="Explain why this payment is being rejected…" required></textarea>
            </div>
            <button type="submit" class="btn btn-danger btn-full" onclick="return confirm('Reject this payment? The fan will be notified.')">
              ❌ Reject Payment
            </button>
          </form>
        </div>

        <!-- Flag -->
        <div class="content-block" style="border-color:rgba(245,158,11,0.25);">
          <h3 style="font-size:var(--text-base);margin-bottom:var(--space-4);color:var(--color-warning);">🚩 Flag for Fraud</h3>
          <form action="/admin/gift-cards/<%= payment._id %>/flag" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Flag Reason</label>
                <input type="text" name="flag" class="form-input" placeholder="e.g. Duplicate card" required>
              </div>
              <div class="form-group">
                <label class="form-label">Severity</label>
                <select name="severity" class="form-select">
                  <option value="low">Low</option>
                  <option value="medium" selected>Medium</option>
                  <option value="high">High</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-warning btn-full" style="background:var(--color-warning);color:#000;">🚩 Flag for Review</button>
          </form>
        </div>
        <% } else { %>
        <div class="content-block">
          <% if (payment.status === 'approved') { %>
          <div style="text-align:center;padding:var(--space-8);">
            <div style="font-size:64px;margin-bottom:var(--space-4);">✅</div>
            <h4 style="color:var(--color-success);">Payment Approved</h4>
            <% if (payment.approvalNotes) { %><p style="color:var(--text-muted);margin-top:var(--space-3);">Notes: <%= payment.approvalNotes %></p><% } %>
            <p style="font-size:var(--text-xs);color:var(--text-muted);margin-top:var(--space-2);">Reviewed: <%= payment.reviewedAt ? new Date(payment.reviewedAt).toLocaleString() : '–' %></p>
          </div>
          <% } else if (payment.status === 'rejected') { %>
          <div style="text-align:center;padding:var(--space-8);">
            <div style="font-size:64px;margin-bottom:var(--space-4);">❌</div>
            <h4 style="color:var(--color-error);">Payment Rejected</h4>
            <% if (payment.rejectionReason) { %><div class="alert alert-error mt-4" style="text-align:left;"><%= payment.rejectionReason %></div><% } %>
          </div>
          <% } %>
        </div>
        <% } %>

      </div>
    </div>
  </main>
</div>

<!-- Image lightbox -->
<div class="modal-overlay" id="imgModal" onclick="closeImage()">
  <div style="max-width:90vw;max-height:90vh;" onclick="event.stopPropagation()">
    <img id="lightboxImg" style="max-width:90vw;max-height:90vh;border-radius:var(--radius-lg);object-fit:contain;" src="" alt="Gift card image">
  </div>
</div>

<%- include('../../partials/footer') %>
<script src="/js/app.js"></script>
<script>
function openImage(url){ document.getElementById('lightboxImg').src=url; document.getElementById('imgModal').classList.add('open'); }
function closeImage(){ document.getElementById('imgModal').classList.remove('open'); }
</script>
</body>
</html>
