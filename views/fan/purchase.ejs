<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<main>
  <div class="container section">
    <div class="grid-2 gap-8" style="max-width:900px;margin:0 auto;">

      <div>
        <img src="<%= event.banner?.url || '/images/defaults/event-banner.jpg' %>" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:var(--radius-lg);margin-bottom:var(--space-5);">
        <h1 style="font-size:var(--text-2xl);font-weight:800;margin-bottom:var(--space-3);"><%= event.title %></h1>
        <div style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-5);">
          <img src="<%= event.celebrity?.profileImage?.url || '/images/defaults/avatar.png' %>" style="width:32px;height:32px;border-radius:50%;object-fit:cover;" onerror="this.src='/images/defaults/avatar.png'">
          <span style="font-weight:600;"><%= event.celebrity?.stageName %></span>
          <% if (event.celebrity?.isVerified) { %>✅<% } %>
        </div>
        <p style="color:var(--text-secondary);line-height:1.75;"><%= event.shortDescription || event.description %></p>

        <div class="content-block mt-6">
          <% [
            ['Date', new Date(event.startDate).toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'})],
            ['Time', new Date(event.startDate).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})],
            ['Venue', event.venue?.name || (event.type === 'virtual' ? 'Virtual Event' : 'TBA')],
          ].forEach(([label,value]) => { %>
          <div style="display:flex;justify-content:space-between;padding:var(--space-3) 0;border-bottom:1px solid var(--border-subtle);">
            <span style="font-size:var(--text-sm);color:var(--text-muted);"><%= label %></span>
            <span style="font-size:var(--text-sm);font-weight:600;"><%= value %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div>
        <% if (existingTicket) { %>
        <div class="content-block" style="text-align:center;padding:var(--space-10);">
          <div style="font-size:48px;margin-bottom:var(--space-4);">🎟️</div>
          <h4 style="margin-bottom:var(--space-3);">You already have a ticket</h4>
          <a href="/fan/tickets/<%= existingTicket._id %>" class="btn btn-primary">View Your Ticket</a>
        </div>
        <% } else { %>
        <div class="content-block">
          <h3 style="font-size:var(--text-lg);margin-bottom:var(--space-5);">Select Ticket Type</h3>
          <form action="/fan/purchase" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="eventId" value="<%= event._id %>">

            <% event.ticketCategories.filter(c => c.isActive).forEach(cat => {
              const soldOut = cat.sold >= cat.capacity;
            %>
            <label style="display:block;border:2px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-4);margin-bottom:var(--space-4);cursor:<%= soldOut ? 'not-allowed' : 'pointer' %>;opacity:<%= soldOut ? '0.5' : '1' %>;">
              <div class="flex-between">
                <div>
                  <input type="radio" name="ticketCategory" value="<%= cat.name %>" <%= soldOut ? 'disabled' : '' %> required style="margin-right:var(--space-2);">
                  <strong><%= cat.label %></strong>
                </div>
                <span style="font-weight:800;font-size:var(--text-lg);">$<%= cat.price %></span>
              </div>
              <div style="font-size:var(--text-xs);color:var(--text-muted);margin:var(--space-2) 0 var(--space-2) 24px;">
                <%= soldOut ? 'Sold Out' : `${cat.capacity - cat.sold} of ${cat.capacity} remaining` %>
              </div>
              <ul style="margin-left:24px;font-size:var(--text-xs);color:var(--text-secondary);">
                <% cat.benefits.forEach(b => { %><li>✓ <%= b %></li><% }) %>
              </ul>
            </label>
            <% }) %>

            <button type="submit" class="btn btn-primary btn-full btn-lg mt-4">Continue to Payment</button>
          </form>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
</body>
</html>