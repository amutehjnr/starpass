<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <button class="btn btn-secondary btn-sm mb-6" id="sidebarToggle" style="display:none;">☰ Menu</button>

    <div class="page-header flex-between">
      <div>
        <h1 class="page-title">My Tickets</h1>
        <p class="page-subtitle"><%= pagination.total %> total tickets</p>
      </div>
      <a href="/events" class="btn btn-primary">Browse Events</a>
    </div>

    <div class="flex gap-2 mb-6" style="flex-wrap:wrap;">
      <% ['all','pending_payment','active','used','cancelled','refunded','expired'].forEach(s => { %>
      <a href="/fan/tickets<%= s === 'all' ? '' : '?status=' + s %>" class="btn btn-sm <%= currentStatus === s ? 'btn-primary' : 'btn-secondary' %>" style="text-transform:capitalize;">
        <%= s.replace('_',' ') %>
      </a>
      <% }) %>
    </div>

    <% if (tickets.length === 0) { %>
    <div class="content-block" style="text-align:center;padding:var(--space-16);">
      <div style="font-size:64px;margin-bottom:var(--space-4);">🎟️</div>
      <h4 style="margin-bottom:var(--space-3);">No tickets found</h4>
      <p style="color:var(--text-muted);margin-bottom:var(--space-6);">Browse events to get your first ticket.</p>
      <a href="/events" class="btn btn-primary">Browse Events</a>
    </div>
    <% } else { %>
    <div class="ticket-grid">
      <% tickets.forEach(ticket => { %>
      <a href="/fan/tickets/<%= ticket._id %>" class="ticket-card ticket-<%= ticket.ticketCategory %>" style="display:block;text-decoration:none;">
        <div class="ticket-card__header">
          <div>
            <div class="ticket-card__event"><%= ticket.event?.title || 'Event' %></div>
            <div class="ticket-card__number"># <%= ticket.ticketNumber %></div>
          </div>
          <span class="badge badge-<%= ticket.status === 'active' ? 'success' : ticket.status === 'pending_payment' ? 'warning' : ticket.status === 'used' ? 'info' : 'error' %>" style="text-transform:capitalize;">
            <%= ticket.status.replace('_',' ') %>
          </span>
        </div>
        <div class="ticket-card__body">
          <div class="ticket-card__row">
            <span class="ticket-card__label">Date</span>
            <span class="ticket-card__value"><%= ticket.event?.startDate ? new Date(ticket.event.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '–' %></span>
          </div>
          <div class="ticket-card__row">
            <span class="ticket-card__label">Category</span>
            <span class="ticket-card__value" style="text-transform:capitalize;"><%= ticket.ticketLabel || ticket.ticketCategory %></span>
          </div>
          <div class="ticket-card__row">
            <span class="ticket-card__label">Price</span>
            <span class="ticket-card__value">$<%= ticket.price %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>

    <% if (pagination.pages > 1) { %>
    <div class="pagination">
      <% for (let p = 1; p <= pagination.pages; p++) { %>
      <a href="/fan/tickets?page=<%= p %><%= currentStatus !== 'all' ? '&status=' + currentStatus : '' %>" class="pagination__btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
      <% } %>
    </div>
    <% } %>
    <% } %>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>