<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header">
      <h1 class="page-title">My Payments</h1>
      <p class="page-subtitle"><%= pagination.total %> total submissions</p>
    </div>

    <div class="flex gap-2 mb-6" style="flex-wrap:wrap;">
      <% ['all','pending','under_review','approved','rejected','expired'].forEach(s => { %>
      <a href="/fan/payments<%= s === 'all' ? '' : '?status=' + s %>" class="btn btn-sm <%= currentStatus === s ? 'btn-primary' : 'btn-secondary' %>" style="text-transform:capitalize;"><%= s.replace('_',' ') %></a>
      <% }) %>
    </div>

    <% if (payments.length === 0) { %>
    <div class="content-block" style="text-align:center;padding:var(--space-16);">
      <div style="font-size:64px;margin-bottom:var(--space-4);">💳</div>
      <h4>No payments found</h4>
    </div>
    <% } else { %>
    <div class="table-wrap content-block" style="padding:0;">
      <table class="table">
        <thead><tr><th>Event</th><th>Card Type</th><th>Value</th><th>Status</th><th>Submitted</th></tr></thead>
        <tbody>
          <% payments.forEach(p => { %>
          <tr>
            <td><%= p.event?.title || '–' %></td>
            <td><span class="badge badge-muted" style="text-transform:capitalize;"><%= p.cardType.replace('_',' ') %></span></td>
            <td style="font-weight:700;">$<%= p.declaredValue %></td>
            <td>
              <span class="badge badge-<%= p.status === 'approved' ? 'success' : p.status === 'rejected' ? 'error' : p.status === 'under_review' ? 'info' : 'warning' %>" style="text-transform:capitalize;">
                <span class="status-dot <%= p.status === 'approved' ? 'active' : p.status %>"></span> <%= p.status.replace('_',' ') %>
              </span>
            </td>
            <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
          </tr>
          <% if (p.status === 'rejected' && p.rejectionReason) { %>
          <tr><td colspan="5" style="background:var(--color-error-bg);font-size:var(--text-xs);"><strong>Reason:</strong> <%= p.rejectionReason %></td></tr>
          <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (pagination.pages > 1) { %>
    <div class="pagination">
      <% for (let i = 1; i <= pagination.pages; i++) { %>
      <a href="/fan/payments?page=<%= i %><%= currentStatus !== 'all' ? '&status=' + currentStatus : '' %>" class="pagination__btn <%= i === pagination.page ? 'active' : '' %>"><%= i %></a>
      <% } %>
    </div>
    <% } %>
    <% } %>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>