<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header">
      <h1 class="page-title">Notifications</h1>
      <p class="page-subtitle"><%= pagination.total %> total</p>
    </div>

    <% if (notifications.length === 0) { %>
    <div class="content-block" style="text-align:center;padding:var(--space-16);">
      <div style="font-size:64px;margin-bottom:var(--space-4);">🔔</div>
      <h4>You're all caught up!</h4>
    </div>
    <% } else { %>
    <div class="content-block" style="padding:0;">
      <% notifications.forEach(n => { %>
      <a href="<%= n.link || '#' %>" style="display:flex;align-items:flex-start;gap:var(--space-4);padding:var(--space-5);border-bottom:1px solid var(--border-subtle);text-decoration:none;color:inherit;<%= !n.isRead ? 'background:rgba(124,58,237,0.04);' : '' %>">
        <div style="width:42px;height:42px;border-radius:50%;background:rgba(124,58,237,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:18px;">
          <%= n.type.includes('payment') ? '💳' : n.type.includes('ticket') ? '🎟️' : n.type.includes('event') ? '🎪' : n.type.includes('fan_club') ? '⭐' : n.type.includes('review') ? '⭐' : '🔔' %>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-weight:600;font-size:var(--text-sm);margin-bottom:2px;"><%= n.title %></div>
          <div style="font-size:var(--text-sm);color:var(--text-secondary);"><%= n.message %></div>
          <div style="font-size:var(--text-xs);color:var(--text-muted);margin-top:6px;"><%= new Date(n.createdAt).toLocaleString() %></div>
        </div>
        <% if (!n.isRead) { %><div style="width:8px;height:8px;border-radius:50%;background:var(--color-brand-fuchsia);flex-shrink:0;margin-top:6px;"></div><% } %>
      </a>
      <% }) %>
    </div>

    <% if (pagination.pages > 1) { %>
    <div class="pagination">
      <% for (let p = 1; p <= pagination.pages; p++) { %>
      <a href="/fan/notifications?page=<%= p %>" class="pagination__btn <%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
      <% } %>
    </div>
    <% } %>
    <% } %>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>