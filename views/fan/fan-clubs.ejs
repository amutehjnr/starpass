<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>

  <main class="dashboard-content">
    <div class="page-header">
      <h1 class="page-title">My Fan Clubs</h1>
      <p class="page-subtitle"><%= fanClubs.length %> joined</p>
    </div>

    <% if (fanClubs.length === 0) { %>
    <div class="content-block" style="text-align:center;padding:var(--space-16);">
      <div style="font-size:64px;margin-bottom:var(--space-4);">⭐</div>
      <h4 style="margin-bottom:var(--space-3);">No fan clubs joined yet</h4>
      <p style="color:var(--text-muted);margin-bottom:var(--space-6);">Join a fan club from any celebrity's profile page.</p>
      <a href="/celebrities" class="btn btn-primary">Browse Celebrities</a>
    </div>
    <% } else { %>
    <div class="grid-3">
      <% fanClubs.forEach(fc => { %>
      <div class="card">
        <div class="card__body" style="text-align:center;">
          <img src="<%= fc.celebrity?.profileImage?.url || '/images/defaults/avatar.png' %>" style="width:72px;height:72px;border-radius:50%;object-fit:cover;margin:0 auto var(--space-4);" onerror="this.src='/images/defaults/avatar.png'">
          <h4 style="margin-bottom:var(--space-2);"><%= fc.name %></h4>
          <p style="font-size:var(--text-xs);color:var(--text-muted);margin-bottom:var(--space-4);"><%= fc.celebrity?.stageName %></p>
          <div class="flex-center gap-2">
            <a href="<%= fc.celebrity?.slug ? '/celebrities/' + fc.celebrity.slug : '/celebrities' %>" class="btn btn-secondary btn-sm">View Celebrity</a>
            <form action="/fan/fan-clubs/<%= fc._id %>/leave" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-ghost btn-sm" onclick="return confirm('Leave this fan club?')">Leave</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

  </main>
</div>

<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>