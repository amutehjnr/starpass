<aside class="dashboard-sidebar" id="dashSidebar">

  <% if (['fan'].includes(currentUser.role)) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Fan Menu</div>
      <a href="/fan/dashboard"      class="sidebar-link <%= currentPath === '/fan/dashboard' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/fan/tickets"        class="sidebar-link <%= currentPath.startsWith('/fan/tickets') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        My Tickets
      </a>
      <a href="/fan/payments"       class="sidebar-link <%= currentPath.startsWith('/fan/payments') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Payments
      </a>
      <a href="/fan/fan-clubs"      class="sidebar-link <%= currentPath.startsWith('/fan/fan-clubs') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Fan Clubs
      </a>
      <a href="/fan/notifications"  class="sidebar-link <%= currentPath.startsWith('/fan/notifications') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
        Notifications
        <span class="sidebar-badge hidden" id="sidebarNotifBadge">0</span>
      </a>
      <a href="/fan/reviews"        class="sidebar-link <%= currentPath.startsWith('/fan/reviews') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Reviews
      </a>
      <a href="/fan/profile"        class="sidebar-link <%= currentPath.startsWith('/fan/profile') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
      <a href="/admin/invitations" class="sidebar-link <%= currentPath.startsWith('/admin/invitations') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
        Invitations
      </a>
    </div>
  <% } %>

  <% if (['celebrity','celebrity_manager','event_organizer'].includes(currentUser.role)) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Celebrity Menu</div>
      <a href="/celebrity/dashboard" class="sidebar-link <%= currentPath === '/celebrity/dashboard' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/celebrity/events"    class="sidebar-link <%= currentPath.startsWith('/celebrity/events') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Events
      </a>
      <a href="/celebrity/fan-club"  class="sidebar-link <%= currentPath.startsWith('/celebrity/fan-club') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Fan Club
      </a>
      <a href="/celebrity/analytics" class="sidebar-link <%= currentPath.startsWith('/celebrity/analytics') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Analytics
      </a>
      <a href="/celebrity/profile"   class="sidebar-link <%= currentPath.startsWith('/celebrity/profile') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </div>
  <% } %>

  <% if (['admin','super_admin','moderator'].includes(currentUser.role)) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Admin</div>
      <a href="/admin/dashboard"   class="sidebar-link <%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/admin/gift-cards"  class="sidebar-link <%= currentPath.startsWith('/admin/gift-cards') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Gift Cards
      </a>
      <a href="/admin/users"       class="sidebar-link <%= currentPath.startsWith('/admin/users') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Users
      </a>
      <a href="/admin/celebrities" class="sidebar-link <%= currentPath.startsWith('/admin/celebrities') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Celebrities
      </a>
      <a href="/admin/events"      class="sidebar-link <%= currentPath.startsWith('/admin/events') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Events
      </a>
      <a href="/admin/reviews"     class="sidebar-link <%= currentPath.startsWith('/admin/reviews') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Reviews
      </a>
      <a href="/admin/audit-logs"  class="sidebar-link <%= currentPath.startsWith('/admin/audit-logs') ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Audit Logs
      </a>
    </div>
  <% } %>

  <!-- Quick Links -->
  <div class="sidebar-section" style="margin-top:auto; padding-top: var(--space-6); border-top: 1px solid var(--border-subtle);">
    <a href="/celebrities" class="sidebar-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      Browse Platform
    </a>
  </div>

</aside>

<!-- Mobile sidebar overlay -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>
